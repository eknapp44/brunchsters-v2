# Brunchsters — Environment Variables
# Copy to apps/web/.env.local and fill in real values. Never commit .env.local.
# Prisma CLI vars (DATABASE_URL, DIRECT_URL) also go in packages/database/.env.
# Local values come from `supabase start` output. See docs/SETUP.md §5.

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection for app runtime (via pgBouncer in prod, direct in local dev)
DATABASE_URL=""
# Direct connection for Prisma migrations (bypasses pooler)
DIRECT_URL=""

# ── Supabase ──────────────────────────────────────────────────────────────────
# From `supabase start` output
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Auth (NextAuth / Auth.js) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Base URL for auth callbacks — http://localhost:3000 locally
AUTH_URL=""

# ── Google OAuth (needed when reaching the auth spec) ────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Apple Sign-In (deferred — $99/year account, add near launch) ─────────────
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── Email — Resend (mock locally until the email spec) ───────────────────────
RESEND_API_KEY=""

# ── Google Places API (mock locally until the location spec) ─────────────────
GOOGLE_PLACES_API_KEY=""

# ── Inngest async job queue (local dev server runs without keys) ──────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Token encryption — AES-256-GCM key for OAuth token storage ───────────────
# Generate with: openssl rand -base64 32
# WARNING: rotating this key invalidates all stored tokens. Never commit.
TOKEN_ENCRYPTION_KEY=""
