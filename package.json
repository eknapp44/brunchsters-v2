{
  "name": "brunchsters",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "eslint . --max-warnings 0",
    "test": "turbo test",
    "dev": "turbo dev",
    "db:migrate": "pnpm --filter @brunchsters/database exec prisma migrate dev",
    "db:generate": "pnpm --filter @brunchsters/database exec prisma generate",
    "db:seed": "pnpm --filter @brunchsters/database run seed",
    "db:validate": "pnpm --filter @brunchsters/database exec prisma validate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0",
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.0",
    "semantic-release": "^25.0.5",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.0.0"
  }
}
